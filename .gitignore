# Secrets — never commit
*.env
.env*
secrets/
credentials/

# OpenClaw sensitive exports
openclaw.json
*.bak

# System
.DS_Store
Thumbs.db

# Large generated outputs — don't bloat git history
outputs/images/
tmp/

# Python virtual environments
**/.venv/
**/venv/

# Node build artifacts in projects (they have their own repos)
projects/*/node_modules/
projects/*/dist/
